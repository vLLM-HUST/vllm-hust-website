#!/usr/bin/env bash
# Pre-commit hook — code quality checks before commit
#
# Checks:
#   1. Trailing whitespace
#   2. Merge conflict markers
#   3. Large files (>5 MB)
#   4. Auto-fix + lint staged Python files with ruff (gracefully skipped if absent)
#   5. Hardcoded API keys in staged Python files
#   6. Debug statements (pdb/breakpoint) in staged Python files

set -eo pipefail

# Colors
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
NC='\033[0m'

PRE_COMMIT_CMD=()

has_python311() {
    if command -v python3.11 >/dev/null 2>&1; then
        return 0
    fi

    if ! command -v python3 >/dev/null 2>&1; then
        return 1
    fi

    local version
    version=$(python3 - <<'PY'
import sys

print(f"{sys.version_info.major}.{sys.version_info.minor}")
PY
)
    [ "$version" = "3.11" ]
}

resolve_pre_commit_cmd() {
    if command -v pre-commit >/dev/null 2>&1; then
        PRE_COMMIT_CMD=(pre-commit)
        return 0
    fi

    if command -v python3 >/dev/null 2>&1 && python3 - <<'PY' >/dev/null 2>&1
import importlib.util
import sys

sys.exit(0 if importlib.util.find_spec("pre_commit") else 1)
PY
    then
        PRE_COMMIT_CMD=(python3 -m pre_commit)
        return 0
    fi

    if command -v uvx >/dev/null 2>&1 && has_python311; then
        PRE_COMMIT_CMD=(uvx --python 3.11 pre-commit)
        return 0
    fi

    return 1
}

echo -e "${CYAN}🔍 Running pre-commit checks...${NC}"

# --- Branch policy ---
CURRENT_BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || echo "")
if [ "$CURRENT_BRANCH" = "main-dev" ]; then
    echo -e "${YELLOW}⚠️  main-dev 已计划退役，建议切换到 main 进行提交。${NC}"
fi

mapfile -t staged_paths < <(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)
if [ "${#staged_paths[@]}" -eq 0 ]; then
    echo -e "${GREEN}✓ No staged changes${NC}"
    exit 0
fi

staged_files=$(printf '%s\n' "${staged_paths[@]}")

if has_python311 && resolve_pre_commit_cmd; then
    echo -e "${CYAN}🚦 Running repository pre-commit on staged files...${NC}"
    if [ "$CURRENT_BRANCH" = "main" ]; then
        SKIP=no-commit-to-branch "${PRE_COMMIT_CMD[@]}" run --files "${staged_paths[@]}"
    else
        "${PRE_COMMIT_CMD[@]}" run --files "${staged_paths[@]}"
    fi
    echo -e "${GREEN}✓ Repository pre-commit checks passed${NC}"
    exit 0
fi

echo -e "${YELLOW}⚠️  CI-equivalent pre-commit is unavailable locally (need pre-commit + Python 3.11).${NC}"
echo -e "${YELLOW}⚠️  Falling back to legacy staged-file checks only. Run ./scripts/validate-local.sh for CI parity.${NC}"

# --- Trailing whitespace ---
if ! git diff --cached --check --diff-filter=ACM 2>/dev/null; then
    echo -e "${RED}✗ Trailing whitespace found. Fix before committing.${NC}"
    exit 1
fi
echo -e "${GREEN}✓ No trailing whitespace${NC}"

# --- Merge conflict markers ---
if git diff --cached 2>/dev/null | grep -qE '^\+(<<<<<<<|=======|>>>>>>>)'; then
    echo -e "${RED}✗ Merge conflict markers found in staged changes${NC}"
    exit 1
fi
echo -e "${GREEN}✓ No conflict markers${NC}"

# --- Large files (>5 MB) ---
max_size=5242880
large=""
while IFS= read -r f; do
    [ -f "$f" ] || continue
    sz=$(stat -c%s "$f" 2>/dev/null || stat -f%z "$f" 2>/dev/null || echo 0)
    [ "$sz" -gt "$max_size" ] && large="${large}  $f ($((sz / 1024 / 1024))MB)\n"
done <<< "$staged_files"
if [ -n "$large" ]; then
    echo -e "${RED}✗ Large files (>5MB) staged:${NC}"
    printf "%b" "$large"
    exit 1
fi
echo -e "${GREEN}✓ No large files${NC}"

# --- Ruff: auto-fix + lint staged Python files ---
mapfile -t staged_py < <(printf '%s\n' "${staged_paths[@]}" | grep '\.py$' || true)
if [ "${#staged_py[@]}" -gt 0 ]; then
    if command -v ruff &>/dev/null; then
        echo -e "${YELLOW}📝 Auto-fixing staged Python files...${NC}"
        ruff format "${staged_py[@]}" 2>/dev/null || true
        ruff check --fix "${staged_py[@]}" 2>/dev/null || true
        # Re-stage auto-fixed files
        git add "${staged_py[@]}"
        echo "🔍 Final lint check on entire repo..."
        if ! ruff check .; then
            echo -e "${RED}✗ ruff check failed. Run 'ruff check --fix .' to fix.${NC}"
            exit 1
        fi
        echo -e "${GREEN}✓ Lint check passed${NC}"
    else
        echo -e "${YELLOW}⚠️  ruff not found, skipping lint${NC}"
    fi
fi

# --- Hardcoded API keys ---
if [ "${#staged_py[@]}" -gt 0 ] && grep -lE "api[_-]key\s*=\s*['\"]sk-" "${staged_py[@]}" 2>/dev/null | grep -q .; then
    echo -e "${RED}✗ Hardcoded API keys detected in staged Python files!${NC}"
    exit 1
fi

# --- Debug statements ---
if [ "${#staged_py[@]}" -gt 0 ] && grep -lE "import pdb|breakpoint\(\)" "${staged_py[@]}" 2>/dev/null | grep -q .; then
    echo -e "${YELLOW}⚠️  Debug statements found (pdb/breakpoint). Use --no-verify to skip.${NC}"
    exit 1
fi

echo -e "${GREEN}✓ All pre-commit checks passed!${NC}"
exit 0
